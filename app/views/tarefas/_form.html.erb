<style>
  .form-group { margin-bottom: 20px; }
  .form-label { display: block; font-weight: bold; color: #374151; margin-bottom: 6px; font-size: 14px; }
  .form-input { width: 100%; padding: 10px; border: 1px solid #d1d5db; border-radius: 8px; box-sizing: border-box; font-size: 15px; }
  .btn-submit { background-color: #10b981; color: white; border: none; padding: 12px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 15px; width: 100%; }
</style>

<%= form_with(model: tarefa) do |form| %>
  <div class="form-group">
    <%= form.label :titulo, "Título da Tarefa", class: "form-label" %>
    <%= form.text_field :titulo, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= form.label :descricao, "Descrição", class: "form-label" %>
    <%= form.text_area :descricao, rows: 4, class: "form-input" %>
  </div>
  <div><%= form.submit "Salvar Tarefa", class: "btn-submit" %></div>
<% end %>
